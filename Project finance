<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title> Projeto 🎅</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Chart.js para gráficos -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <!-- Confetti para celebração -->
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.5.1/dist/confetti.browser.min.js"></script>
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Mountains+of+Christmas:wght@400;700&family=Inter:wght@400;500;700;900&display=swap" rel="stylesheet">
    
    <style>
        :root { 
            --xmas-red: #be123c; 
            --xmas-green: #15803d; 
            --xmas-gold: #fbbf24; 
        }
        
        body { 
            font-family: 'Inter', sans-serif;
            background: radial-gradient(circle at top, #1e293b 0%, #0f172a 100%);
            color: #f8fafc;
        }
        
        .font-christmas { 
            font-family: 'Mountains of Christmas', cursive; 
        }
        
        .glass { 
            background: rgba(255, 255, 255, 0.05); 
            backdrop-filter: blur(12px); 
            border: 1px solid rgba(255,255,255,0.1); 
        }
        
        .card-inner { 
            transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); 
        }
        
        .card-inner:hover { 
            transform: scale(1.02); 
        }
        
        /* Neve aprimorada */
        .snowflake { 
            position: fixed; 
            top: -10px; 
            color: white; 
            pointer-events: none; 
            z-index: 50; 
            animation: fall linear infinite; 
        }
        
        @keyframes fall { 
            to { 
                transform: translateY(105vh) rotate(360deg); 
            } 
        }
        
        /* Scrollbar customizada */
        .custom-scrollbar::-webkit-scrollbar {
            width: 6px;
        }
        
        .custom-scrollbar::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 10px;
        }
        
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.2);
            border-radius: 10px;
        }
        
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 255, 255, 0.3);
        }
        
        /* Firefox */
        .custom-scrollbar {
            scrollbar-color: rgba(255, 255, 255, 0.2) rgba(255, 255, 255, 0.05);
            scrollbar-width: thin;
        }
        
        button:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }
    </style>
</head>
<body class="min-h-screen pb-20">

    <div class="max-w-5xl mx-auto px-4 pt-12">
        <!-- Header Harmônico -->
        <header class="text-center mb-12">
            <span class="inline-block px-4 py-1 rounded-full bg-red-500/20 text-red-400 text-sm font-bold mb-4 border border-red-500/30">Temporada 2026</span>
            <h1 class="text-6xl font-black font-christmas text-white drop-shadow-[0_0_15px_rgba(220,38,38,0.5)]">Financeiro de Natal</h1>
            <p class="text-slate-400 mt-4 max-w-md mx-auto">Gerencie seus presentes e ceia com precisão cirúrgica e espírito festivo.</p>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            
            <!-- Painel Esquerdo: Controle -->
            <div class="lg:col-span-4 space-y-6">
                <!-- Status Card -->
                <div class="glass p-6 rounded-3xl border-t-4 border-yellow-500 shadow-2xl">
                    <p class="text-slate-400 text-sm font-bold uppercase tracking-tighter">Balanço Geral</p>
                    <h2 id="balance" class="text-4xl font-black mt-1 text-white">R$ 0,00</h2>
                    <div class="mt-6 flex justify-between gap-2">
                        <div class="text-green-400">
                            <span class="text-[10px] block font-bold opacity-70">ENTRADAS</span>
                            <span id="money-plus" class="text-lg font-bold">+ R$ 0,00</span>
                        </div>
                        <div class="text-red-400 text-right">
                            <span class="text-[10px] block font-bold opacity-70">SAÍDAS</span>
                            <span id="money-minus" class="text-lg font-bold">- R$ 0,00</span>
                        </div>
                    </div>
                </div>

                <!-- Formulário com Categorias -->
                <div class="glass p-6 rounded-3xl">
                    <form id="form" class="space-y-4">
                        <div>
                            <label class="text-xs font-bold text-slate-400 uppercase">Descrição</label>
                            <input 
                                type="text" 
                                id="text" 
                                placeholder="Ex: Panetone Gourmet" 
                                maxlength="50"
                                class="w-full bg-slate-800/50 border border-slate-700 p-3 rounded-xl focus:ring-2 ring-red-500 outline-none transition-all"
                            >
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="text-xs font-bold text-slate-400 uppercase">Valor</label>
                                <input 
                                    type="number" 
                                    step="0.01" 
                                    min="0"
                                    id="amount" 
                                    placeholder="0.00" 
                                    class="w-full bg-slate-800/50 border border-slate-700 p-3 rounded-xl focus:ring-2 ring-red-500 outline-none"
                                >
                            </div>
                            <div>
                                <label class="text-xs font-bold text-slate-400 uppercase">Tipo</label>
                                <select id="type" class="w-full bg-slate-800/50 border border-slate-700 p-3 rounded-xl outline-none focus:ring-2 ring-red-500 transition-all">
                                    <option value="expense">Gasto 🎅</option>
                                    <option value="income">Renda 🎁</option>
                                </select>
                            </div>
                        </div>
                        <button 
                            type="submit"
                            class="w-full bg-red-600 hover:bg-red-500 disabled:bg-red-800 text-white font-bold py-4 rounded-xl shadow-lg shadow-red-900/20 transition-all flex justify-center items-center gap-2"
                        >
                            Registrar Transação <span>✨</span>
                        </button>
                    </form>
                </div>
            </div>

            <!-- Painel Direito: Visualização e Lista -->
            <div class="lg:col-span-8 space-y-6">
                <!-- Gráfico de Gastos -->
                <div class="glass p-6 rounded-3xl h-64 relative">
                    <canvas id="financeChart"></canvas>
                </div>

                <!-- Lista de Transações -->
                <div class="space-y-4">
                    <div class="flex justify-between items-center px-2">
                        <h3 class="font-bold text-xl flex items-center gap-2">Histórico <span class="text-sm bg-slate-700 px-2 py-1 rounded text-slate-300" id="item-count">0</span></h3>
                        <button 
                            onclick="clearHistory()" 
                            class="text-xs text-slate-500 hover:text-red-400 transition-colors uppercase font-bold"
                        >
                            Limpar Tudo
                        </button>
                    </div>
                    <ul id="list" class="space-y-3 max-h-[400px] overflow-y-auto pr-2 custom-scrollbar">
                        <!-- Transações injetadas via JS -->
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <script>
        /**
         * ARQUITETURA DE DADOS (Expansividade)
         * Gerenciador completo de transações com validação e tratamento de erros
         */
        class FinanceManager {
            constructor() {
                this.transactions = [];
                this.chart = null;
                this.loadTransactions();
            }

            /**
             * Carrega transações do localStorage com tratamento de erro
             */
            loadTransactions() {
                try {
                    const data = localStorage.getItem('xmas_pro_data');
                    this.transactions = data ? JSON.parse(data) : [];
                } catch (error) {
                    console.error('Erro ao carregar dados do localStorage:', error);
                    this.transactions = [];
                    alert('Aviso: Não foi possível carregar dados anteriores.');
                }
            }

            /**
             * Formata valor para moeda brasileira
             */
            formatCurrency(value) {
                return new Intl.NumberFormat('pt-BR', {
                    style: 'currency',
                    currency: 'BRL'
                }).format(Math.abs(value));
            }

            /**
             * Escapa HTML para prevenir XSS
             */
            escapeHtml(text) {
                const map = {
                    '&': '&amp;',
                    '<': '&lt;',
                    '>': '&gt;',
                    '"': '&quot;',
                    "'": '&#039;'
                };
                return text.replace(/[&<>"']/g, m => map[m]);
            }

            /**
             * Adiciona nova transação com validação
             */
            add(text, amount, type) {
                // Validação
                if (!text || !text.trim()) {
                    throw new Error('Descrição não pode estar vazia');
                }
                if (!amount || isNaN(amount) || amount <= 0) {
                    throw new Error('Valor deve ser maior que zero');
                }

                const val = type === 'expense' ? -Math.abs(amount) : Math.abs(amount);
                const transaction = {
                    id: Date.now(),
                    text: text.trim(),
                    amount: parseFloat(val.toFixed(2)),
                    date: new Date().toLocaleDateString('pt-BR')
                };

                this.transactions.push(transaction);
                this.save();
                
                if (val > 0) {
                    this.celebrate();
                }
                
                return transaction;
            }

            /**
             * Deleta transação por ID
             */
            delete(id) {
                const initial = this.transactions.length;
                this.transactions = this.transactions.filter(t => t.id !== id);
                
                if (this.transactions.length < initial) {
                    this.save();
                }
            }

            /**
             * Salva dados no localStorage e atualiza UI
             */
            save() {
                try {
                    localStorage.setItem('xmas_pro_data', JSON.stringify(this.transactions));
                    this.updateUI();
                } catch (error) {
                    console.error('Erro ao salvar dados:', error);
                    alert('Erro ao salvar dados. Espaço de armazenamento pode estar cheio.');
                }
            }

            /**
             * Ativa celebração com confetti
             */
            celebrate() {
                if (typeof confetti !== 'undefined') {
                    confetti({
                        particleCount: 100,
                        spread: 70,
                        origin: { y: 0.6 },
                        colors: ['#ff0000', '#00ff00', '#ffffff']
                    });
                }
            }

            /**
             * Atualiza toda a UI
             */
            updateUI() {
                this.updateBalance();
                this.updateTransactionList();
                this.updateChart();
            }

            /**
             * Atualiza balanço e totais
             */
            updateBalance() {
                const amounts = this.transactions.map(t => t.amount);
                const total = amounts.reduce((acc, val) => acc + val, 0);
                const income = amounts.filter(v => v > 0).reduce((a, v) => a + v, 0);
                const expense = amounts.filter(v => v < 0).reduce((a, v) => a + v, 0);

                document.getElementById('balance').textContent = this.formatCurrency(total);
                document.getElementById('money-plus').textContent = `+ ${this.formatCurrency(income)}`;
                document.getElementById('money-minus').textContent = `- ${this.formatCurrency(Math.abs(expense))}`;
                document.getElementById('item-count').textContent = this.transactions.length;

                return { total, income, expense };
            }

            /**
             * Atualiza lista de transações
             */
            updateTransactionList() {
                const list = document.getElementById('list');
                list.innerHTML = '';

                // Cria cópia invertida para não modificar o array original
                [...this.transactions].reverse().forEach(t => {
                    const isExpense = t.amount < 0;
                    const li = document.createElement('li');
                    li.className = 'glass flex justify-between items-center p-4 rounded-2xl card-inner cursor-default';
                    li.innerHTML = `
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 rounded-full flex items-center justify-center text-lg ${
                                isExpense ? 'bg-red-500/20 text-red-500' : 'bg-green-500/20 text-green-500'
                            }">
                                ${isExpense ? '📉' : '💰'}
                            </div>
                            <div>
                                <p class="font-bold text-slate-200">${this.escapeHtml(t.text)}</p>
                                <p class="text-[10px] text-slate-500 font-bold">${t.date}</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-4">
                            <span class="font-black ${isExpense ? 'text-red-400' : 'text-green-400'}">
                                ${isExpense ? '-' : '+'} ${this.formatCurrency(t.amount)}
                            </span>
                            <button class="delete-btn text-slate-600 hover:text-red-500 transition-colors text-xl" data-id="${t.id}" title="Deletar transação">✕</button>
                        </div>
                    `;
                    list.appendChild(li);
                });

                // Delegação de eventos para botões de delete
                list.removeEventListener('click', this.handleDeleteClick);
                list.addEventListener('click', this.handleDeleteClick.bind(this));
            }

            /**
             * Handler para clique em botão de delete
             */
            handleDeleteClick(e) {
                if (e.target.classList.contains('delete-btn')) {
                    const id = parseInt(e.target.dataset.id);
                    if (confirm('Deseja deletar esta transação?')) {
                        this.delete(id);
                    }
                }
            }

            /**
             * Atualiza gráfico de gastos vs ganhos
             */
            updateChart() {
                const { income, expense } = this.updateBalance();
                const ctx = document.getElementById('financeChart');
                
                if (!ctx) return;

                if (this.chart) {
                    this.chart.destroy();
                }

                const incomeVal = Math.max(income, 0);
                const expenseVal = Math.max(Math.abs(expense), 0);

                this.chart = new Chart(ctx.getContext('2d'), {
                    type: 'doughnut',
                    data: {
                        labels: ['Ganhos', 'Gastos'],
                        datasets: [{
                            data: [incomeVal, expenseVal],
                            backgroundColor: ['#15803d', '#be123c'],
                            borderWidth: 0,
                            hoverOffset: 10
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: true,
                                position: 'right',
                                labels: {
                                    color: '#94a3b8',
                                    font: { weight: 'bold', size: 12 },
                                    padding: 20
                                }
                            },
                            tooltip: {
                                callbacks: {
                                    label: (context) => {
                                        return this.formatCurrency(context.parsed);
                                    }
                                }
                            }
                        }
                    }
                });
            }
        }

        // ========== INICIALIZAÇÃO ==========
        const app = new FinanceManager();
        const form = document.getElementById('form');
        const submitBtn = form.querySelector('button[type="submit"]');

        /**
         * Event listener para submit do formulário
         */
        form.addEventListener('submit', (e) => {
            e.preventDefault();

            const text = document.getElementById('text').value;
            const amount = document.getElementById('amount').value;
            const type = document.getElementById('type').value;

            // Desabilita botão durante processamento
            submitBtn.disabled = true;

            try {
                app.add(text, parseFloat(amount), type);
                form.reset();
                document.getElementById('text').focus();
            } catch (error) {
                alert(`Erro: ${error.message}`);
                console.error(error);
            } finally {
                submitBtn.disabled = false;
            }
        });

        /**
         * Limpa todo o histórico
         */
        function clearHistory() {
            if (confirm('Deseja zerar sua jornada de Natal? Esta ação não pode ser desfeita.')) {
                app.transactions = [];
                app.save();
            }
        }

        /**
         * Sistema de neve animada
         */
        function createSnowflake() {
            const snowflake = document.createElement('div');
            snowflake.innerHTML = '❄';
            snowflake.className = 'snowflake';
            snowflake.style.left = Math.random() * 100 + 'vw';
            snowflake.style.animationDuration = (Math.random() * 3 + 2) + 's';
            snowflake.style.opacity = Math.random() * 0.7 + 0.3;
            snowflake.style.fontSize = (Math.random() * 10 + 10) + 'px';
            document.body.appendChild(snowflake);
            setTimeout(() => snowflake.remove(), 5000);
        }

        // Cria neve a cada 300ms
        const snowInterval = setInterval(createSnowflake, 300);

        // Inicializa UI
        app.updateUI();

        // Cleanup ao descarregar página
        window.addEventListener('beforeunload', () => {
            clearInterval(snowInterval);
            if (app.chart) {
                app.chart.destroy();
            }
        });
    </script>
</body>
</html>
